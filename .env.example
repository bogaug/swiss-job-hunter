# ─────────────────────────────────────────
# Swiss Job Hunter – Configurazione ambiente
# Copia questo file in .env e compila i campi
# ─────────────────────────────────────────

# Groq API Key — gratuita su https://console.groq.com
GROQ_API_KEY=gsk_...

# Adzuna API — opzionale, gratuita su https://developer.adzuna.com (amplia i risultati)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# ── Profilo candidato ─────────────────────
CANDIDATE_NAME=Mario Rossi
CANDIDATE_EMAIL=mario.rossi@email.ch
CANDIDATE_ROLE=Data Engineer
CANDIDATE_SKILLS=Python, SQL, ETL, Apache Spark, Power BI, Docker, Azure, BigQuery
CANDIDATE_EDUCATION=BSc Data Engineering, HEIA-FR / HES-SO (2025)
CANDIDATE_EXPERIENCE=Assistant Data Analyst, Cornèr Banque SA
CANDIDATE_LANGUAGES=Italiano (madrelingua), Francese C1, Inglese C1

# ── SMTP – Gmail ───────────────────────────
# Per Gmail: attiva la verifica 2 passaggi e genera un'App Password
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tuaemail@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx

# ── SMTP – Outlook / Office 365 ────────────
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587
# SMTP_USER=tuaemail@outlook.com
# SMTP_PASSWORD=password

# ── SMTP – Proton Mail (Bridge) ────────────
# SMTP_HOST=127.0.0.1
# SMTP_PORT=1025
# SMTP_USER=tuaemail@proton.me
# SMTP_PASSWORD=bridge_password
